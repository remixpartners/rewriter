.DS_Store
*.pyc
__pycache__/
.env
*.skill

# Voice guides capture personal communication patterns -- keep real guides out of the public repo.
# The folder, its README, and EXAMPLE.md DO ship (so the skill works on install); every real *.md guide stays local.
# To deliberately version-control a specific guide, force-add it: git add -f voices/<name>.md
voices/*.md
!voices/README.md
!voices/EXAMPLE.md
